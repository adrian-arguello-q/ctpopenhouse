<h1>Editar estudiante</h1>

<%
  const pageError = typeof error !== 'undefined' ? error : null;
  const pageEstudiante = typeof estudiante !== 'undefined' ? estudiante : {};
%>

<form method="POST" action="/actualizar/<%= pageEstudiante.id %>">
  <% if (pageError) { %>
    <p style="color:red;"><%= pageError %></p>
  <% } %>
  <input name="nombre" value="<%= pageEstudiante.nombre %>" placeholder="Nombre" required>
  <input name="colegio" value="<%= estudiante.colegio %>" placeholder="Colegio" required>
  <input type="email" name="correo" value="<%= estudiante.correo %>" placeholder="Correo" required>
  <input type="number" name="interes" inputmode="numeric" pattern="[0-9]*" min="0" step="1" placeholder="Interes" value="<%= estudiante.interes %>" required>

  <select name="especialidad" required>
    <option value="">Seleccione una especialidad</option>
    <% especialidades.forEach(especialidad => { %>
      <option value="<%= especialidad.idespecialidades %>" <%= estudiante.especialidad == especialidad.idespecialidades ? "selected" : "" %>><%= especialidad.nomespecialidad %></option>
    <% }) %>
  </select>

  <select name="examen">
    <option value="SI" <%= estudiante.examen === "SI" ? "selected" : "" %>>Sí pienso hacer el examen</option>
    <option value="NO" <%= estudiante.examen === "NO" ? "selected" : "" %>>No pienso hacer el examen</option>
  </select>

  <select name="estado">
    <option value="ACT" <%= estudiante.estado === "ACT" ? "selected" : "" %>>Activo</option>
    <option value="INA" <%= estudiante.estado === "INA" ? "selected" : "" %>>Inactivo</option>
  </select>

  <button type="submit">Actualizar</button>
</form>

<a href="/">Volver</a>